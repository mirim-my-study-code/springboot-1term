<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">
    <!--  태그 : TestBean인 객체를 만드는 명령   -->
    <bean id="t1" class="kr.hs.study.beans.TestBean1"/>
    <bean id="t2" class="kr.hs.study.beans.TestBean1">
        <constructor-arg value="2" type="int" index="0"/>
    </bean>
    <bean id="t3" class="kr.hs.study.beans.TestBean1" lazy-init="true">
        <constructor-arg value="3.333" type="double"/>
    </bean>

    <bean id="dataBean2" class="kr.hs.study.beans.DataBean2"/>
    <bean id="testBean2" class="kr.hs.study.beans.TestBean2">
        <constructor-arg ref="dataBean2"/>
        <constructor-arg ref="dataBean2"/>
    </bean>
</beans>